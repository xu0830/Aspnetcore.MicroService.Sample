{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ApplicationName": "user-service",
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:9002"
      }
    }
  },
  "Consul": {
    "Host": "localhost",
    "Port": 8500,
    "Discovery": {
      "ServiceName": "user-service",
      "HealthCheckPath": "/health",
      "HealthCheckInterval": "10s",
      "HealthCheckTimeout": "5s",
      "HealthCheckCriticalTimeout": "10s",
      "Hostname": "192.168.220.1",
      "Port": 9002,
      "InstanceId": "user-service-192.168.220.1-9002",
      "Tags": [ "user-service" ],
      "Heartbeat": { // consul心跳包  
        "Enabled": true,
        "TtlValue": 20
      },
      "Retry": {
        "Enabled": true
      }
    }
  },
  "ConnectionStrings": {
    "dbContext": "server=127.0.0.1;port=3306;database=userDB;user=root;password=123456"
  }
}
